# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# Single answer-generation call (Phase 2)
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings — OpenAI text-embedding-3-large (offline ingestion)
OPENAI_API_KEY=sk-...

# Optional: alternative finance-domain embedding provider (swappable behind the Embedder protocol)
# VOYAGE_API_KEY=

# --- Optional config overrides (defaults shown; see src/config.py) ---
# EMBEDDING_MODEL=text-embedding-3-large
# GENERATION_MODEL=claude-opus-4-8
# CHUNK_MAX_CHARS=3000
# CHUNK_OVERLAP=300
# VECTOR_TOP_K=20
# BM25_TOP_K=20
# RRF_K=60
# RERANK_TOP_K=8
# RERANK_MODEL=BAAI/bge-reranker-base   # local cross-encoder (needs: pip install sentence-transformers)
# MIN_SIMILARITY=0.35
