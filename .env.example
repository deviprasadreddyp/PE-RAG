# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# Embeddings and generation default to OpenAI.
OPENAI_API_KEY=sk-...

# Optional: LangSmith tracing (prompt/tokens/latency for every answer call). Leave blank to disable.
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_PROJECT=PE-RAG

# --- Optional config overrides (defaults shown; see src/config.py) ---
# EMBEDDING_MODEL=text-embedding-3-large    # or text-embedding-3-small; BAAI/bge-* still works locally
# GENERATION_MODEL=gpt-5.5
# GENERATION_MAX_OUTPUT_TOKENS=3500
# GENERATION_REASONING_EFFORT=medium
# GENERATION_VERBOSITY=medium
# CHUNK_MAX_CHARS=3000
# CHUNK_OVERLAP=300
# VECTOR_TOP_K=20
# BM25_TOP_K=20
# RRF_K=60
# RERANK_TOP_K=8
# RERANK_MODEL=BAAI/bge-reranker-base       # or BAAI/bge-reranker-large
# MIN_SIMILARITY=0.35
