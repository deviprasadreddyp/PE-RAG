# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# The ONLY key the system needs: the single grounded answer call goes through OpenRouter
# (OpenAI-compatible). Embeddings (BAAI/bge-large-en-v1.5) and the reranker run locally, no key.
OPENROUTER_API_KEY=sk-or-...

# Optional: LangSmith tracing (prompt/tokens/latency for every answer call). Leave blank to disable.
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_PROJECT=PE-RAG

# --- Optional config overrides (defaults shown; see src/config.py) ---
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5    # local sentence-transformers model
# GENERATION_MODEL=openai/gpt-4o            # any OpenRouter model id (e.g. openai/gpt-4o-mini)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# CHUNK_MAX_CHARS=3000
# CHUNK_OVERLAP=300
# VECTOR_TOP_K=20
# BM25_TOP_K=20
# RRF_K=60
# RERANK_TOP_K=8
# RERANK_MODEL=BAAI/bge-reranker-base       # or BAAI/bge-reranker-large
# MIN_SIMILARITY=0.35
