# =============================================================================
# PE-RAG .gitignore
# =============================================================================

# --- Secrets & environment ---------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
secrets.*
credentials.json
service-account*.json

# --- Dataset (excluded from VCS — see README "Getting the corpus") -----------
edgar_corpus/*.txt
!edgar_corpus/manifest.json
*.zip

# --- Generated data, vector indexes & caches ---------------------------------
data/
outputs/
.cache/
chroma/
*.chroma
chroma.sqlite3
*.faiss
*.index
*.duckdb
embedding_cache/
bm25_index/
.embeddings/

# --- ML / model artifacts ----------------------------------------------------
models/
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.gguf
.huggingface/
.cache/huggingface/
sentence_transformers_cache/
torch_cache/

# --- Python bytecode & build -------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual environments ----------------------------------------------------
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.python-version
Pipfile.lock
poetry.lock
.pdm-python
__pypackages__/

# --- Testing, coverage & type/lint caches ------------------------------------
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# --- Jupyter / IPython -------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py
.jupyter/

# --- Streamlit ---------------------------------------------------------------
.streamlit/secrets.toml

# --- Logs & temp -------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
*.bak
*.pid
*.seed
tmp/
scratch/

# --- Node (in case any JS tooling is added) ----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS files ----------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
# Linux
.directory
.Trash-*
.nfs*

# --- Editors / IDEs ----------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.iws
*.ipr
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.\#*
\#*\#
